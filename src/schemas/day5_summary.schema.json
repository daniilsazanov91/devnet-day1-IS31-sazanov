{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "schema_version",
    "student",
    "yang",
    "webex",
    "pt",
    "validation_passed"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "student": {
      "type": "object",
      "required": ["token_hash8", "name", "group"],
      "properties": {
        "token": { "type": ["string", "null"] },
        "token_hash8": { "type": "string" },
        "name": { "type": "string" },
        "group": { "type": "string" }
      }
    },
    "yang": {
      "type": "object",
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" },
        "evidence_sha": { "type": ["string", "null"] }
      }
    },
    "webex": {
      "type": "object",
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" },
        "room_title_contains_hash8": { "type": "boolean" },
        "evidence_sha": { "type": ["string", "null"] }
      }
    },
    "pt": {
      "type": "object",
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" },
        "empty_ticket_seen": { "type": "boolean" },
        "evidence_sha": { "type": ["string", "null"] }
      }
    },
    "validation_passed": {
      "type": "boolean"
    }
  }
}
